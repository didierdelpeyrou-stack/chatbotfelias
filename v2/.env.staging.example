# V2 ELISFA — Staging (template Sprint 4.4 + Sprint 5.2-stack)
# Copier en `.env.staging` sur le VPS, remplir, NE PAS committer.

# ── Anthropic ──
# Réutiliser la même clé que V1 (rate limits Anthropic = par compte, pas par app)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
CLAUDE_MODEL=claude-haiku-4-5-20251001
CLAUDE_MAX_TOKENS=2000
CLAUDE_TIMEOUT_SECONDS=30

# ── App ──
ENVIRONMENT=staging
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000
APP_NAME="Chatbot ELISFA V2 (staging)"

# ── RAG (calibrés Sprint 4.1-4.2 + Sprint 5.2-stack) ──
RAG_TOP_K=5
RAG_SCORE_MIN_HORS_CORPUS=1.5

# ── Voyage AI — embeddings sémantiques (Sprint 5.2-stack Phase A1) ──
# Compte gratuit : https://dash.voyageai.com (50M tokens free tier)
# Si vide, V2 fonctionne en TF-IDF seul (fallback gracieux).
# Avec Voyage actif + LLM-judge : V2 = 75.2% (IC95 [71, 79.5]).
VOYAGE_API_KEY=pa-xxxxxxxxxxxxxxxxxxxxxxxx
VOYAGE_MODEL=voyage-3-large
# Pondération hybride : score = α·tfidf_norm + (1-α)·cosine_voyage_norm
RAG_HYBRID_ALPHA=0.5
# Skip embeddings si tfidf_normalized > seuil (gain latence ~30% requêtes)
RAG_SKIP_EMBEDDING_THRESHOLD=0.85

# ── KB ──
# Path absolu dans le container Docker.
# /app/data/v2 = KB V2 enrichie Sprint 5.2-data (271 articles dont 156 formation)
# Le cache embeddings (_embeddings_*.npz, ~1 MB) doit aussi être dans ce volume
# pour éviter le boot de 20+ minutes (free tier Voyage rate-limit).
# Pour fallback sur KB V1 (158 articles), mettre /app/data (déconseillé).
KB_DATA_DIR=/app/data/v2

# ── Observability ──
METRICS_ENABLED=true

# ── Feedback (Sprint 4.3) ──
# Chemin du JSONL dans le container — monté sur volume hôte (/var/lib/elisfa-v2/logs)
ELISFA_FEEDBACK_LOG=/app/logs/feedback.jsonl
