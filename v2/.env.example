# V2 ELISFA — variables d'environnement (template)
# Copier en `.env` (qui est dans .gitignore) et remplir les valeurs.

# ── Anthropic ──
# Récupérer sur https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Modèle utilisé en V2 (aligné avec V1 pendant la cohabitation)
CLAUDE_MODEL=claude-haiku-4-5-20251001
CLAUDE_MAX_TOKENS=2000

# ── App ──
ENVIRONMENT=development
LOG_LEVEL=INFO
HOST=127.0.0.1
PORT=8000

# ── RAG (calibrés Sprint 4) ──
RAG_TOP_K=5
RAG_SCORE_MIN_HORS_CORPUS=1.5
RAG_MAX_LIENS_PAR_REPONSE=6
RAG_MAX_FICHES_PAR_REPONSE=5

# ── Observability ──
METRICS_PORT=9092
METRICS_ENABLED=true
