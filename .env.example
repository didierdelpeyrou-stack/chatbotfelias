# ═══════════════════════════════════════════════════════════
#  ELISFA Chatbot — Configuration Environnement
#  Copiez ce fichier en .env et remplissez vos valeurs
# ═══════════════════════════════════════════════════════════

# ── API Anthropic (Claude) ──
# Obtenez votre clé sur https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# Modèle IA : claude-haiku-4-5-20251001 (rapide/économique) | claude-sonnet-4-20250514 (équilibré) | claude-opus-4-20250514 (puissant)
CLAUDE_MODEL=claude-haiku-4-5-20251001
CLAUDE_MAX_TOKENS=2000

# ── Serveur ──
PORT=5000
HOST=0.0.0.0
FLASK_DEBUG=false
SECRET_KEY=changez-moi-avec-une-clef-secrete-longue

# ── Email SMTP (notifications juriste + confirmations adhérents) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre-email@gmail.com
SMTP_PASS=votre-mot-de-passe-application
SMTP_FROM=chatbot@elisfa.fr
JURISTE_EMAIL=juridique@elisfa.fr

# ── Webhook MCP (n8n / Zapier / Make) ──
# URL pour recevoir les notifications sortantes
NOTIFICATION_WEBHOOK_URL=
# Clé secrète pour sécuriser les webhooks entrants
WEBHOOK_SECRET=elisfa-webhook-secret-change-me

# ── Intégration Calendrier ──
# URL Calendly (ex: https://calendly.com/elisfa-juridique)
CALENDLY_URL=
# URL Cal.com (ex: https://cal.com/elisfa-juridique)
CALCOM_URL=
# Google Calendar ID
GOOGLE_CALENDAR_ID=

# ── Admin endpoints (/api/stats, /api/reload, /admin, /api/rdv, /api/appels) ──
# Identifiant admin
ADMIN_USER=admin
# Hash bcrypt du mot de passe admin — JAMAIS le mot de passe en clair.
# Génération : python scripts/generate_admin_hash.py --random
# ⚠️  IMPORTANT docker-compose : dans le .env réel, échapper chaque $ en $$
#    (ex: ADMIN_PASS_HASH=$$2b$$12$$...). Sinon docker-compose interprète
#    $2b, $12 comme des références de variables et corrompt le hash.
ADMIN_PASS_HASH=

# ── Rate Limiting ──
RATE_LIMIT_PER_MINUTE=20
RATE_LIMIT_PER_HOUR=100

# ── Observabilité (optionnel) ──
# Sentry DSN pour le monitoring d'erreurs. Laisser vide = no-op.
SENTRY_DSN=
# Environnement Sentry (prod / staging / dev)
SENTRY_ENVIRONMENT=prod

# ── CORS ──
CORS_ORIGINS=*
